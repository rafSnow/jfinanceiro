{
  "name": "Transaction",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome da pessoa respons\u00e1vel"
    },
    "type": {
      "type": "string",
      "enum": [
        "receita",
        "despesa"
      ],
      "description": "Tipo de transa\u00e7\u00e3o"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "Pix",
        "Dinheiro",
        "Cart\u00e3o"
      ],
      "description": "Forma de pagamento"
    },
    "status": {
      "type": "string",
      "enum": [
        "Pago",
        "Pendente",
        "Recebido"
      ],
      "default": "Pendente"
    },
    "amount": {
      "type": "number",
      "description": "Valor da transa\u00e7\u00e3o"
    },
    "description": {
      "type": "string",
      "description": "Descri\u00e7\u00e3o da transa\u00e7\u00e3o"
    },
    "category": {
      "type": "string",
      "enum": [
        "Moradia",
        "Alimenta\u00e7\u00e3o",
        "Transporte",
        "Lazer",
        "Sa\u00fade",
        "Outros"
      ],
      "description": "Categoria da despesa"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Data de vencimento"
    },
    "month": {
      "type": "string",
      "description": "M\u00eas de refer\u00eancia (ex: 2026-06)"
    },
    "scope": {
      "type": "string",
      "enum": [
        "pessoal",
        "empresa"
      ],
      "default": "pessoal",
      "description": "Escopo: pessoal ou empresa"
    }
  },
  "required": [
    "name",
    "type",
    "amount",
    "description",
    "month"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "created_by_id": "{{user.id}}"
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}